    "walkthroughs": [
      {
        "id": "rapidLiveQuickStart",
        "title": "Get started with RAPID Live",
        "description": "Connect to your first ABB controller and edit RAPID code from VS Code.",
        "steps": [
          {
            "id": "add",
            "title": "Add a robot",
            "description": "Click the **+ Add Robot** button in the **Robots** panel (left activity bar — robot icon). The wizard auto-detects RobotStudio virtual controllers on localhost; or enter your real controller's IP and credentials.\n\n[Open the Robots panel](command:workbench.view.extension.abbRobot)",
            "completionEvents": [
              "onCommand:abbRobot.addRobot"
            ],
            "media": {
              "markdown": "media/walkthrough/add.md"
            }
          },
          {
            "id": "connect",
            "title": "Connect to your robot",
            "description": "Right-click the robot in the Robots panel → **Connect**. The status bar will turn green and the **Live Cell** panel will populate with joint angles, TCP position, and execution state.",
            "completionEvents": [
              "onContext:abbRobot.connected"
            ],
            "media": {
              "markdown": "media/walkthrough/connect.md"
            }
          },
          {
            "id": "open",
            "title": "Open a loaded module",
            "description": "In the **Modules** panel, find a program module (`MotionTest`, `user`, etc.) and click the **Open in Editor** icon. The live RAPID source from the controller opens in a new editor tab — fully syntax-highlighted, with hover docs from the official manual.",
            "completionEvents": [
              "onCommand:abbRobot.openModuleSource"
            ],
            "media": {
              "markdown": "media/walkthrough/open.md"
            }
          },
          {
            "id": "push",
            "title": "Edit and push back",
            "description": "Make a change to the .mod file, save it (Ctrl+S), then right-click in the editor → **Push Current File to Controller**. The controller picks up your change immediately.",
            "completionEvents": [
              "onCommand:abbRobot.pushCurrentFile"
            ],
            "media": {
              "markdown": "media/walkthrough/push.md"
            }
          },
          {
            "id": "watch",
            "title": "Watch live variables",
            "description": "Hover any RAPID variable in the editor while connected to see its current value from the controller. To pin a variable so its value is always visible, select it and right-click → **Add Selection to Variable Watch**.",
            "completionEvents": [
              "onCommand:abbRobot.addWatch"
            ],
            "media": {
              "markdown": "media/walkthrough/watch.md"
            }
          }
        ]
      }
    ],
