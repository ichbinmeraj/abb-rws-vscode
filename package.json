          "group": "1_modification@10"
        },
        {
          "command": "abbRobot.pushCurrentFile",
          "when": "resourceLangId == rapid && resourceScheme != abb-controller",
          "group": "1_modification@11"
        },
        {
          "command": "abbRobot.diffWithController",
          "when": "resourceLangId == rapid && resourceScheme != abb-controller",
          "group": "1_modification@12"
        }
      ],
