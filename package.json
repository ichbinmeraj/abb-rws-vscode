    "viewsWelcome": [
      {
        "view": "abbRobot.robots",
        "contents": "No robots configured yet.\n\n[$(plus) Add Robot](command:abbRobot.addRobot)\n\n[$(search) Auto-detect VC on localhost](command:abbRobot.connect)\n\nNew here? Open the [getting started](command:workbench.action.openWalkthrough?%22merajsafari.abb-rws%23rapidLiveQuickStart%22) walkthrough."
      },
      {
        "view": "abbRobot.liveCell",
        "contents": "Connect to a robot to see live cell state.\n\n[$(plug) Connect](command:abbRobot.connect)",
        "when": "!abbRobot.connected"
      },
      {
        "view": "abbRobot.program",
        "contents": "Connect to a robot to see loaded modules and pinned variables.\n\n[$(plug) Connect](command:abbRobot.connect)",
        "when": "!abbRobot.connected"
      },
      {
        "view": "abbRobot.controllerData",
        "contents": "Connect to browse files, I/O signals, and configuration.\n\n[$(plug) Connect](command:abbRobot.connect)",
        "when": "!abbRobot.connected"
      },
      {
        "view": "abbRobot.diagnostics",
        "contents": "Connect to see event log, motion details, and system info.\n\n[$(plug) Connect](command:abbRobot.connect)",
        "when": "!abbRobot.connected"
      }
