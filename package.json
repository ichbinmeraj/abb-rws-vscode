{
  "name": "abb-rws",
  "displayName": "RAPID Live — ABB Robotics for VS Code",
  "description": "The only VS Code extension that connects to live ABB IRC5 (RobotWare 6) and OmniCore (RobotWare 7) controllers. Live-tested on RW7.21 + RW6.16. RAPID language server (hover docs, autocomplete, signature help, go-to-definition, inlay hints with live values, CodeLens), git-style push/pull/diff workflow for .mod files, multi-robot management, real-time WebSocket subscriptions, IK + FK, file/IO/event-log access, variable watch panel, dual RWS 1.0 + 2.0 protocol support.",
  "version": "0.9.2",
  "publisher": "merajsafari",
  "author": {
    "name": "Meraj Safari"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ichbinmeraj/abb-rws-vscode"
  },
  "keywords": [
    "ABB",
    "robot",
    "IRC5",
    "OmniCore",
    "RWS",
    "RWS 1.0",
    "RWS 2.0",
    "RAPID",
    "RobotWare",
    "RobotWare 6",
    "RobotWare 7",
    "RW6",
    "RW7",
    "RobotStudio",
    "automation",
    "robotics",
    "industrial",
    "robot-web-services"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other",
    "Debuggers"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "rapid",
        "aliases": [
          "RAPID",
          "ABB RAPID"
        ],
        "extensions": [
          ".mod",
          ".sys",
          ".prg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rapid",
        "scopeName": "source.rapid",
        "path": "./syntaxes/rapid.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "rapid",
        "path": "./snippets/rapid.json"
      }
    ],
    "configuration": {
      "title": "ABB Robot",
      "properties": {
        "abbRobot.robots": {
          "type": "array",
          "default": [],
          "description": "List of saved robot controllers. Each entry: { id, name, host, username, password }.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "host": {
                "type": "string",
                "description": "IP address or hostname"
              },
              "username": {
                "type": "string",
                "default": "Admin"
              },
              "password": {
                "type": "string",
                "default": "robotics"
              }
            },
            "required": [
              "id",
              "name",
              "host",
              "username",
              "password"
            ]
          }
        },
        "abbRobot.host": {
          "type": "string",
          "default": "192.168.125.1",
          "description": "(Legacy) Single-robot host — use abbRobot.robots for multi-robot"
        },
        "abbRobot.username": {
          "type": "string",
          "default": "Admin",
          "description": "(Legacy) RWS username"
        },
        "abbRobot.password": {
          "type": "string",
          "default": "robotics",
          "description": "(Legacy) RWS password"
        },
        "abbRobot.refreshInterval": {
          "type": "number",
          "default": 1000,
          "minimum": 200,
          "description": "Status polling interval in ms"
        },
        "abbRobot.jog.increment": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "description": "Jog distance per click — degrees in Joint mode, mm in Cartesian mode"
        },
        "abbRobot.jog.speed": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "maximum": 100,
          "description": "Jog speed (0-100). Start low until you trust the jog increment."
        },
        "abbRobot.jog.mode": {
          "type": "string",
          "default": "Joint",
          "enum": [
            "Joint",
            "Cartesian"
          ],
          "description": "Joint jogs single axes; Cartesian jogs the tool in world coordinates."
        }
      }
    },
